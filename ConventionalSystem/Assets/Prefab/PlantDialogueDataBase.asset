  _dialogueDataList:
  - AgentUtteranceData:
      AgentUtterance: "\u571F\u304C\u4E7E\u71E5\u3057\u3066\u3044\u307E\u3059\u3002\u7D66\u6C34\u3057\u3066\u304F\u3060\u3055\u3044\u3002"
      AgentEmotionBehaviorType: 1
    UserExpectedUtterances:
    - "\u308F\u304B\u3063\u305F\u3002\u3058\u3083\u3042\u3001\u6C34\u3092\u3042\u3052\u3066\u307F\u308B\u306D\u3002"
    - "\u307B\u3089\u3001\u6C34\u3002\u3061\u3083\u3093\u3068\u98F2\u3093\u3067\u306D\u3002"
    - "\u5927\u4E08\u592B\uFF1F \u3059\u3054\u304F\u6691\u3044\u3082\u3093\u306D\u3002\u3053\u308C\u3001\u6C34\u98F2\u3093\u3067\u3002"
    - "\u304A\u30FC\u3044\u3001\u751F\u304D\u3066\u308B\uFF1F\u3000\u307B\u3089\u3001\u6C34\u3084\u308B\u3088\u3002"
    - "\u3053\u306E\u307E\u307E\u3060\u3068\u5E72\u304B\u3089\u3073\u3061\u3083\u3046\u3088\u3002\u306F\u3044\u3001\u6C34\u3069\u3046\u305E\u3002"
    - "\u7121\u7406\u3057\u306A\u3044\u3067\u3002\u3053\u308C\u3001\u6C34\u3001\u98F2\u3093\u3067\u304F\u3060\u3055\u3044\u3002"
    - "\u308F\u304B\u308A\u307E\u3057\u305F"
    - "\u627F\u77E5\u3057\u307E\u3057\u305F"
    Index: 0
  - AgentUtteranceData:
      AgentUtterance: "\u78BA\u8A8D\u3057\u307E\u3057\u305F\u3002\u3042\u308A\u304C\u3068\u3046\u3054\u3056\u3044\u307E\u3057\u305F\u3002"
      AgentEmotionBehaviorType: 1
    UserExpectedUtterances: []
    Index: 1
  _askingBackAgentResponseList:
  - "\u3059\u307F\u307E\u305B\u3093\u3002\u97F3\u58F0\u3092\u6B63\u78BA\u306B\u8A8D\u8B58\u3067\u304D\u307E\u305B\u3093\u3067\u3057\u305F\u3002\u3082\u3046\u4E00\u5EA6\u304A\u9858\u3044\u3057\u307E\u3059\u3002"
  - "\u3046\u307E\u304F\u805E\u304D\u53D6\u308C\u307E\u305B\u3093\u3067\u3057\u305F\u3002\u7E70\u308A\u8FD4\u3057\u3066\u304A\u9858\u3044\u3057\u307E\u3059\u3002"
  - "\u805E\u304D\u53D6\u308C\u307E\u305B\u3093\u3067\u3057\u305F\u3002\u5225\u306E\u8A00\u3044\u65B9\u3067\u304A\u9858\u3044\u3057\u307E\u3059\u3002"
